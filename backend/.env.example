# ── CORRER ENVIRONMENT VARIABLES ─────────────────────────────────────────────
# Copy this file to .env and fill in your real credentials
# NEVER commit .env to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
BASE_URL=https://correr.co.uk   # your production domain (no trailing slash)

# ── Strava ────────────────────────────────────────────────────────────────────
# Create your app at: https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: correr.co.uk
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_VERIFY_TOKEN=correr_strava_webhook_2024   # any random string you choose

# ── Garmin ────────────────────────────────────────────────────────────────────
# Apply for access at: https://developerportal.garmin.com/developer-programs/connect-developer-api
# The Training API requires business approval — apply via the developer portal
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret
# Garmin uses OAuth 1.0a (not 2.0) — keys above are for the Training API

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./correr.db   # SQLite file path (relative to backend/)
